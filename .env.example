# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Local dev only — do NOT set AUTH_URL to localhost on Vercel (redirects will break).
# On Vercel: omit AUTH_URL or set to https://your-app.vercel.app
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Express backend (same as platform)
NEXT_PUBLIC_API_URL=https://processing-facility-backend.onrender.com

# Supabase (server-side only for pickup sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Processing facility coordinates (Haversine + fuel estimate)
NEXT_PUBLIC_FACILITY_LAT=-7.123456
NEXT_PUBLIC_FACILITY_LNG=110.123456

# Optional: override coffee variety dropdown
# NEXT_PUBLIC_COFFEE_VARIETIES=Cobra,Kopyol,Andungsari,S795,Kartika,Other
